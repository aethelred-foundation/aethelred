{
  "name": "@aethelred/bridge-contracts",
  "version": "1.0.0",
  "description": "Aethelred Bridge Ethereum Smart Contracts - Enterprise Lock-and-Mint Bridge",
  "license": "Apache-2.0",
  "author": "Aethelred Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/aethelred-foundation/contracts.git"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "ALLOW_UNLIMITED_CONTRACT_SIZE=true hardhat test",
    "test:coverage": "ALLOW_UNLIMITED_CONTRACT_SIZE=true hardhat coverage",
    "test:gas": "ALLOW_UNLIMITED_CONTRACT_SIZE=true REPORT_GAS=true hardhat test",
    "deploy:devnet": "hardhat run scripts/deploy.ts --network devnet",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mainnet",
    "verify:sepolia": "node -e \"console.log('Etherscan verification is handled in the dedicated contracts repository release process.')\"",
    "verify:mainnet": "node -e \"console.log('Etherscan verification is handled in the dedicated contracts repository release process.')\"",
    "upgrade:devnet": "hardhat run scripts/upgrade.ts --network devnet",
    "upgrade:sepolia": "hardhat run scripts/upgrade.ts --network sepolia",
    "upgrade:mainnet": "hardhat run scripts/upgrade.ts --network mainnet",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix",
    "format": "prettier --write 'contracts/**/*.sol' 'scripts/**/*.ts' 'test/**/*.ts'",
    "clean": "hardhat clean",
    "size": "hardhat size-contracts",
    "size:check": "hardhat compile && node scripts/check-contract-size.js",
    "slither": "slither . --config-file slither.config.json",
    "mythril": "myth analyze contracts/AethelredBridge.sol --solc-json mythril.config.json",
    "docgen": "node -e \"console.log('Contract doc generation now lives in the dedicated contracts repository release process.')\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "chai": "^6.2.2",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "hardhat-contract-sizer": "^2.10.0",
    "prettier": "^3.1.0",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "^5.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "handlebars": "4.7.9",
    "lodash": "4.18.1",
    "ethereum-cryptography": "^3.2.0",
    "picomatch": "4.0.4",
    "serialize-javascript": "7.0.5",
    "flatted": "^3.4.2",
    "undici": "^6.24.0",
    "fast-xml-parser": "^5.5.7",
    "immutable": "^4.3.8",
    "socket.io-parser": "^4.2.6",
    "underscore": "^1.13.8",
    "cookie": "^0.7.0",
    "tmp": "^0.2.4",
    "h3": "^1.15.9",
    "brace-expansion": "^2.0.3",
    "@tootallnate/once": "^3.0.1",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.31",
    "minimatch": "^9.0.7"
  }
}
