# =============================================================================
# Aethelred Backend Environment Configuration
# =============================================================================

# =============================================================================
# Network Configuration
# =============================================================================

# Chain ID (aethelred-1 for mainnet, aethelred-testnet-1 for testnet)
CHAIN_ID=aethelred-1

# Node moniker (display name)
MONIKER=my-aethelred-validator

# External IP address (for P2P)
EXTERNAL_IP=

# =============================================================================
# Node Configuration
# =============================================================================

# Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Minimum gas prices (in aeth)
MINIMUM_GAS_PRICES=0.025aeth

# Pruning strategy (default, nothing, everything, custom)
PRUNING=default

# Indexer type (kv, psql, null)
INDEXER=kv

# =============================================================================
# API Configuration
# =============================================================================

# Node environment (development, production)
NODE_ENV=production

# API port
PORT=3000

# RPC URL for connecting to the node
RPC_URL=http://aethelred-node:26657

# gRPC URL
GRPC_URL=http://aethelred-node:9090

# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# Database connection URL
DATABASE_URL=postgresql://aethelred:changeme@localhost:5432/aethelred?schema=public

# Database credentials (for Docker Compose)
DB_USER=aethelred
DB_PASSWORD=changeme_secure_password_here
DB_NAME=aethelred

# =============================================================================
# Cache Configuration (Redis)
# =============================================================================

# Redis URL
REDIS_URL=redis://localhost:6379

# Redis password (if required)
REDIS_PASSWORD=

# =============================================================================
# Security Configuration
# =============================================================================

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_generate_a_secure_random_string

# API key for admin endpoints
ADMIN_API_KEY=your_admin_api_key_here

# Rate limiting enabled
RATE_LIMIT_ENABLED=true

# Max requests per minute per IP
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Prometheus metrics enabled
METRICS_ENABLED=true

# Jaeger tracing endpoint
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# Grafana Configuration
# =============================================================================

GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3002

# =============================================================================
# Indexer Configuration
# =============================================================================

# Start height for indexing (0 for genesis)
INDEXER_START_HEIGHT=0

# Batch size for indexing
INDEXER_BATCH_SIZE=100

# Indexer mode (realtime, catchup, both)
INDEXER_MODE=both

# =============================================================================
# TEE Configuration (for validators)
# =============================================================================

# TEE enabled
TEE_ENABLED=false

# TEE type (sgx, tdx, sev-snp, nitro)
TEE_TYPE=sgx

# TEE quote path
TEE_QUOTE_PATH=/dev/attestation/quote

# =============================================================================
# Validator Configuration
# =============================================================================

# Validator mode enabled
VALIDATOR_MODE=false

# Validator key file path
VALIDATOR_KEY_FILE=/data/config/priv_validator_key.json

# Validator state file path
VALIDATOR_STATE_FILE=/data/data/priv_validator_state.json

# =============================================================================
# Genesis Configuration (for new networks)
# =============================================================================

# Genesis time (ISO 8601 format)
GENESIS_TIME=2026-03-07T00:00:00Z

# Initial validators (comma-separated addresses)
INITIAL_VALIDATORS=

# Initial balances format: address:amount,address:amount
INITIAL_BALANCES=
