{
  "name": "@aethelred/cruzible",
  "version": "1.0.0",
  "description": "Aethelred Blockchain Explorer and Dashboard - Production Grade",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --maxWorkers=2",
    "test:changed": "jest --onlyChanged",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky install",
    "security:audit": "npm audit --audit-level=moderate",
    "analyze": "cross-env ANALYZE=true next build",
    "postbuild": "next-sitemap",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@tanstack/react-query": "^5.17.9",
    "wagmi": "^2.12.0",
    "viem": "^2.17.0",
    "@walletconnect/ethereum-provider": "^2.13.0",
    "recharts": "^2.10.3",
    "lucide-react": "^0.311.0",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "zod": "^3.22.4",
    "@hookform/resolvers": "^3.3.4",
    "react-hook-form": "^7.49.3",
    "@sentry/nextjs": "^7.93.0",
    "@vercel/analytics": "^1.1.1",
    "@vercel/speed-insights": "^1.0.2",
    "next-sitemap": "^4.2.3",
    "sharp": "^0.33.1",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "@tailwindcss/forms": "^0.5.7",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "eslint-plugin-jest-dom": "^5.1.0",
    "prettier": "^3.2.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/user-event": "^14.5.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@playwright/test": "^1.40.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "cross-env": "^7.0.3",
    "@next/bundle-analyzer": "^14.1.0",
    "msw": "^2.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
