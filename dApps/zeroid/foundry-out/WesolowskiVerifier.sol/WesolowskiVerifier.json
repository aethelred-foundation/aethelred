;;;;:::o;:::-;;;;;;;-1:-1:-1;;;;;1508:2:15;;;;;:::o;:::-;;;;;;;-1:-1:-1;;;;;1508:2:15;;;;;:::o;:::-;;;;;;;;;;;;;;;;:::o;7957:1149::-;;1319:8992;;8109:37;8110:23;:19;;;:::i;8109:37::-;8164:23;;;;:::i;:::-;8263:13;8275:1;8278:12;;;;;;7957:1149;;;;:::o;8292:3::-;8275:1;1508:2;8576:19;8589:5;;;:::i;:::-;8576:19;:::i;:::-;8565:30;;8589:5;;8627:29;8637:19;8650:5;;;:::i;8637:19::-;8627:29;;:::i;:::-;8561:262;;8275:1;8905:150;8925:13;;;;;;9069:20;;;;8132:1;9069:20;;;;;:::i;:::-;1448:17;1508:2;8263:13;;8940:3;8995:13;;;8132:1;8995:13;8976:35;8984:26;8990:19;;8995:13;;;;:::i;:::-;8990:19;;:::i;:::-;1319:8992;-1:-1:-1;;;;;;1319:8992:15;;;8990:19;1319:8992;;;;8984:26;1448:17;;1319:8992;;8976:35;9016:23;9021:17;:13;;;;:::i;:::-;:17;:::i;:::-;9016:23;:::i;:::-;1319:8992;8963:77;8940:3;1508:2;8910:13;;;;8561:262;8742:13;8275:1;8785:23;8795:13;;;:::i;8785:23::-;8561:262;;9202:836;;;;9322:20;;;:::i;:::-;1319:8992;;;9399:13;9411:1;9414:12;;;;;;9202:836;;;;:::o;9428:3::-;9461:8;;;;:::i;:::-;1508:2;;9667:5;9654:19;9667:5;;;:::i;9654:19::-;9641:32;;9667:5;;9705:31;9717:19;9730:5;;;:::i;9705:31::-;9637:221;;9411:1;9892:13;;;;;;9428:3;;;;9671:1;1508:2;9399:13;;9907:3;9978:13;9951:56;9958:48;10001:4;9978:13;9973:23;9978:17;9671:1;9978:13;;;;:::i;9973:23::-;1448:17;9964:41;1448:17;;1319:8992;;9958:48;1319:8992;;-1:-1:-1;;;;;;1319:8992:15;;;9951:56;9930:77;9934:13;;;;:::i;:::-;9930:77;9411:1;9930:77;;;;:::i;:::-;;1508:2;9877:13;;9637:221;9775:13;;9411:1;9818:25;9830:13;;;:::i;9818:25::-;9637:221;;","linkReferences":{}},"methodIdentifiers":{"verifyExponentiation(bytes,bytes,uint256,bytes,bytes)":"6c03cb4d"},"rawMetadata":"{\"compiler\":{\"version\":\"0.8.28+commit.7893614a\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[],\"name\":\"ModexpCallFailed\",\"type\":\"error\"},{\"inputs\":[{\"internalType\":\"bytes\",\"name\":\"base\",\"type\":\"bytes\"},{\"internalType\":\"bytes\",\"name\":\"result\",\"type\":\"bytes\"},{\"internalType\":\"uint256\",\"name\":\"remainder\",\"type\":\"uint256\"},{\"internalType\":\"bytes\",\"name\":\"quotient\",\"type\":\"bytes\"},{\"internalType\":\"bytes\",\"name\":\"modulus\",\"type\":\"bytes\"}],\"name\":\"verifyExponentiation\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"ZeroID Cryptography Team\",\"details\":\"Given a claim V' = V^x mod N, the prover supplies quotient Q where:        Q = V^{floor(x / l)} mod N      and l = H(V, V') | 1 is a Fiat-Shamir challenge derived from the claim      only (base and result), NOT from Q, avoiding a circular dependency.      The verifier checks:        Q^l \\u00b7 V^r \\u2261 V' (mod N)      where r = x mod l (pre-computed by the caller and validated here).      Computation steps:        1. Re-derive l = H(V, V') | 1 (Fiat-Shamir, independent of caller and Q)        2. MODEXP: Q^l mod N        3. MODEXP: V^r mod N        4. Modular multiplication: (Q^l \\u00b7 V^r) mod N, using 128-bit limb           schoolbook multiplication followed by MODEXP reduction        5. Compare with V'      The 128-bit limb multiplication reduces a 256\\u00d7256-byte multiply from      65,536 byte-level iterations to 256 limb-level iterations (16\\u00d716 limbs),      keeping gas under typical block limits.\",\"kind\":\"dev\",\"methods\":{\"verifyExponentiation(bytes,bytes,uint256,bytes,bytes)\":{\"params\":{\"base\":\"The base value V (big-endian, modulus-sized)\",\"modulus\":\"RSA modulus N (big-endian)\",\"quotient\":\"Wesolowski quotient Q (big-endian, modulus-sized)\",\"remainder\":\"Pre-computed r = exponent mod l, where l = H(base, result) | 1\",\"result\":\"The claimed result V' = V^exponent mod modulus (big-endian)\"},\"returns\":{\"valid\":\"   True if Q^l \\u00b7 V^r \\u2261 V' (mod N), with l re-derived internally\"}}},\"title\":\"WesolowskiVerifier\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"verifyExponentiation(bytes,bytes,uint256,bytes,bytes)\":{\"notice\":\"Verify a Wesolowski proof of exponentiation.\"}},\"notice\":\"On-chain verification of Wesolowski proofs of exponentiation using the         EVM MODEXP precompile (address 0x05).\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/verifiers/WesolowskiVerifier.sol\":\"WesolowskiVerifier\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":eth-gas-reporter/=node_modules/eth-gas-reporter/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":hardhat/=node_modules/hardhat/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"contracts/interfaces/IExponentiationVerifier.sol\":{\"keccak256\":\"0x781f2ac812d2b57b919b30b9d81d4eca5ae9a45a52e4ce6221f6720bbb06e68a\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://4d2a294295402fe0b8a709fc2cdf21c913931bbb365b59672e494fddb7bd397f\",\"dweb:/ipfs/QmUphUcBBDktsQyxwvpfVa9Q818kKet5EFfC7fgBxPkgPx\"]},\"contracts/verifiers/WesolowskiVerifier.sol\":{\"keccak256\":\"0xc1b0836f2a46b11dc2a755d3d9b051930445aa5d023ecac3d53a01e867dc1fab\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://774e8bcfa039a9077429b4decd6b0b43aa39944eb827277324858e51fb055a05\",\"dweb:/ipfs/QmPTNoNSYXKLcgwvMnF5Xq5cAKSfCWmyPk3BvSeGu2V5Xb\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.28+commit.7893614a"},"language":"Solidity","output":{"abi":[{"inputs":[],"type":"error","name":"ModexpCallFailed"},{"inputs":[{"internalType":"bytes","name":"base","type":"bytes"},{"internalType":"bytes","name":"result","type":"bytes"},{"internalType":"uint256","name":"remainder","type":"uint256"},{"internalType":"bytes","name":"quotient","type":"bytes"},{"internalType":"bytes","name":"modulus","type":"bytes"}],"stateMutability":"view","type":"function","name":"verifyExponentiation","outputs":[{"internalType":"bool","name":"valid","type":"bool"}]}],"devdoc":{"kind":"dev","methods":{"verifyExponentiation(bytes,bytes,uint256,bytes,bytes)":{"params":{"base":"The base value V (big-endian, modulus-sized)","modulus":"RSA modulus N (big-endian)","quotient":"Wesolowski quotient Q (big-endian, modulus-sized)","remainder":"Pre-computed r = exponent mod l, where l = H(base, result) | 1","result":"The claimed result V' = V^exponent mod modulus (big-endian)"},"returns":{"valid":"   True if Q^l · V^r ≡ V' (mod N), with l re-derived internally"}}},"version":1},"userdoc":{"kind":"user","methods":{"verifyExponentiation(bytes,bytes,uint256,bytes,bytes)":{"notice":"Verify a Wesolowski proof of exponentiation."}},"version":1}},"settings":{"remappings":["@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/","erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/","eth-gas-reporter/=node_modules/eth-gas-reporter/","forge-std/=lib/forge-std/src/","halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/","hardhat/=node_modules/hardhat/","openzeppelin-contracts/=lib/openzeppelin-contracts/"],"optimizer":{"enabled":true,"runs":200},"metadata":{"bytecodeHash":"ipfs"},"compilationTarget":{"contracts/verifiers/WesolowskiVerifier.sol":"WesolowskiVerifier"},"evmVersion":"prague","libraries":{},"viaIR":true},"sources":{"contracts/interfaces/IExponentiationVerifier.sol":{"keccak256":"0x781f2ac812d2b57b919b30b9d81d4eca5ae9a45a52e4ce6221f6720bbb06e68a","urls":["bzz-raw://4d2a294295402fe0b8a709fc2cdf21c913931bbb365b59672e494fddb7bd397f","dweb:/ipfs/QmUphUcBBDktsQyxwvpfVa9Q818kKet5EFfC7fgBxPkgPx"],"license":"MIT"},"contracts/verifiers/WesolowskiVerifier.sol":{"keccak256":"0xc1b0836f2a46b11dc2a755d3d9b051930445aa5d023ecac3d53a01e867dc1fab","urls":["bzz-raw://774e8bcfa039a9077429b4decd6b0b43aa39944eb827277324858e51fb055a05","dweb:/ipfs/QmPTNoNSYXKLcgwvMnF5Xq5cAKSfCWmyPk3BvSeGu2V5Xb"],"license":"MIT"}},"