{
  "version": 1,
  "effective_date": "2026-03-13",
  "purpose": "Defines the minimum repo-local auditability baseline required in each public Aethelred repository.",
  "baseline_required_files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "SUPPORT.md",
    "CODE_OF_CONDUCT.md",
    "repo-role.json",
    "docs/security/threat-model.md",
    "docs/security/release-provenance.md",
    ".github/workflows/docs-hygiene.yml",
    ".github/workflows/repo-security-baseline.yml"
  ],
  "repos": [
    {
      "repo": "aethelred-foundation/aethelred",
      "role": "canonical-monorepo",
      "advanced_expected_workflows": [
        ".github/workflows/repo-authority-guard.yml",
        ".github/workflows/release.yml",
        ".github/workflows/release-please.yml",
        ".github/workflows/security.yml",
        ".github/workflows/security-scans.yml"
      ],
      "advanced_expected_docs": [
        "docs/security/release-provenance.md"
      ]
    },
    {
      "repo": "aethelred-foundation/contracts",
      "role": "smart-contracts",
      "advanced_expected_workflows": [
        ".github/workflows/contracts-ci.yml"
      ]
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-ts",
      "role": "sdk-typescript",
      "advanced_expected_workflows": [
        ".github/workflows/sdk-typescript-tests.yml"
      ]
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-py",
      "role": "sdk-python",
      "advanced_expected_workflows": [
        ".github/workflows/sdk-python-tests.yml"
      ]
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-go",
      "role": "sdk-go",
      "advanced_expected_workflows": [
        ".github/workflows/sdk-go-tests.yml"
      ]
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-rs",
      "role": "sdk-rust",
      "advanced_expected_workflows": [
        ".github/workflows/sdk-rust-tests.yml"
      ]
    },
    {
      "repo": "aethelred-foundation/aethelred-cli",
      "role": "developer-cli"
    },
    {
      "repo": "aethelred-foundation/vscode-aethelred",
      "role": "editor-extension"
    },
    {
      "repo": "aethelred-foundation/aethelred-docs",
      "role": "documentation-site",
      "advanced_expected_workflows": [
        ".github/workflows/docs-hygiene.yml"
      ]
    },
    {
      "repo": "aethelred-foundation/AIPs",
      "role": "governance-specs"
    },
    {
      "repo": "aethelred-foundation/cruzible",
      "role": "application-frontend"
    },
    {
      "repo": "aethelred-foundation/.github",
      "role": "org-control-plane",
      "advanced_expected_workflows": [
        ".github/workflows/docs-hygiene.yml"
      ],
      "advanced_expected_docs": [
        "profile/README.md"
      ]
    }
  ]
}
