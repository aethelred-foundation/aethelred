{
  "version": 1,
  "effective_date": "2026-03-13",
  "ratification_status": "pending-foundation-ratification",
  "ratification_record": "docs/governance/adr-0001-chain-repo-authority-canonicalization.md",
  "purpose": "Repository authority and release provenance registry for the public Aethelred GitHub organization.",
  "authority_groups": [
    {
      "id": "chain-go",
      "description": "Canonical public chain implementation track",
      "canonical_repo": "aethelred-foundation/aethelred",
      "canonical_go_module": "github.com/aethelred/aethelred",
      "allow_duplicate_go_module_during_transition": false
    }
  ],
  "repos": [
    {
      "repo": "aethelred-foundation/aethelred",
      "role": "canonical-chain",
      "authority_group": "chain-go",
      "release_authority": true,
      "declared_modules": {
        "go": [
          "github.com/aethelred/aethelred"
        ]
      }
    },
    {
      "repo": "aethelred-foundation/contracts",
      "role": "smart-contracts",
      "authority_group": "contracts",
      "release_authority": true
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-ts",
      "role": "sdk-typescript",
      "authority_group": "sdk",
      "release_authority": true
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-py",
      "role": "sdk-python",
      "authority_group": "sdk",
      "release_authority": true
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-go",
      "role": "sdk-go",
      "authority_group": "sdk",
      "release_authority": true
    },
    {
      "repo": "aethelred-foundation/aethelred-sdk-rs",
      "role": "sdk-rust",
      "authority_group": "sdk",
      "release_authority": true
    },
    {
      "repo": "aethelred-foundation/aethelred-cli",
