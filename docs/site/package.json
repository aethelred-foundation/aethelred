{
    "name": "aethelred-docs",
    "version": "1.0.0",
    "private": true,
    "description": "Aethelred SDK Documentation Site",
    "scripts": {
        "dev": "vitepress dev docs",
        "build": "vitepress build docs",
        "preview": "vitepress preview docs",
