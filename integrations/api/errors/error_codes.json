{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aethelred Error Code Specification",
  "description": "Shared error code specification for all Aethelred SDKs (Python, Rust, Go, TypeScript)",
  "version": "1.0.0",
  "categories": {
    "VALIDATION": {
      "description": "Input validation errors",
      "code_range": [1000, 1999]
    },
    "CONSENSUS": {
      "description": "Consensus-related errors",
      "code_range": [2000, 2999]
    },
    "CRYPTO": {
      "description": "Cryptographic operation errors",
      "code_range": [3000, 3999]
    },
    "TEE": {
      "description": "Trusted Execution Environment errors",
      "code_range": [4000, 4999]
    },
    "NETWORK": {
      "description": "Network and RPC errors",
      "code_range": [5000, 5999]
    },
    "STORAGE": {
      "description": "Storage and persistence errors",
      "code_range": [6000, 6999]
    },
    "ZKML": {
      "description": "Zero-Knowledge ML proof errors",
      "code_range": [7000, 7999]
    },
    "BRIDGE": {
      "description": "Cross-chain bridge errors",
      "code_range": [8000, 8999]
    },
    "INTERNAL": {
      "description": "Internal system errors",
      "code_range": [9000, 9999]
    }
  },
  "errors": {
    "VALIDATION_INVALID_ADDRESS": {
      "code": 1001,
      "category": "VALIDATION",
      "message": "Invalid account address format",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "address": {"type": "string"},
          "expected_format": {"type": "string"}
        }
      }
    },
    "VALIDATION_INVALID_HASH": {
      "code": 1002,
      "category": "VALIDATION",
      "message": "Invalid hash format or length",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "hash": {"type": "string"},
          "expected_length": {"type": "integer"}
        }
      }
    },
    "VALIDATION_INVALID_PROOF_TYPE": {
      "code": 1003,
      "category": "VALIDATION",
      "message": "Invalid or unsupported proof type",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "provided": {"type": "string"},
          "allowed": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "VALIDATION_MISSING_REQUIRED_FIELD": {
      "code": 1004,
      "category": "VALIDATION",
      "message": "Required field is missing",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "field": {"type": "string"}
        }
      }
    },
    "VALIDATION_FIELD_TOO_LONG": {
      "code": 1005,
      "category": "VALIDATION",
      "message": "Field exceeds maximum length",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "field": {"type": "string"},
          "max_length": {"type": "integer"},
          "actual_length": {"type": "integer"}
        }
      }
    },
    "VALIDATION_INVALID_FEE": {
      "code": 1006,
      "category": "VALIDATION",
      "message": "Fee amount is invalid or below minimum",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "provided": {"type": "string"},
          "minimum": {"type": "string"}
        }
      }
    },
    "VALIDATION_INVALID_SIGNATURE": {
      "code": 1007,
      "category": "VALIDATION",
      "message": "Signature format is invalid",
      "retryable": false,
      "http_status": 400
    },
    "VALIDATION_EXPIRED_REQUEST": {
      "code": 1008,
      "category": "VALIDATION",
      "message": "Request has expired",
      "retryable": false,
      "http_status": 400,
      "details_schema": {
        "type": "object",
        "properties": {
          "expired_at": {"type": "string", "format": "date-time"}
        }
      }
    },

    "CONSENSUS_JOB_NOT_FOUND": {
      "code": 2001,
      "category": "CONSENSUS",
      "message": "Compute job not found",
      "retryable": false,
      "http_status": 404,
      "details_schema": {
        "type": "object",
