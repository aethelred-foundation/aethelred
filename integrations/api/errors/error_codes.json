    "CONSENSUS_JOB_EXPIRED": {
      "code": 2003,
      "category": "CONSENSUS",
      "message": "Job has expired before completion",
      "retryable": false,
      "http_status": 410
    },
    "CONSENSUS_INSUFFICIENT_VERIFICATIONS": {
      "code": 2004,
      "category": "CONSENSUS",
      "message": "Insufficient validator verifications",
      "retryable": true,
      "http_status": 425,
      "details_schema": {
        "type": "object",
        "properties": {
          "required": {"type": "integer"},
          "received": {"type": "integer"}
        }
      }
    },
    "CONSENSUS_VERIFICATION_MISMATCH": {
      "code": 2005,
      "category": "CONSENSUS",
      "message": "Validator verification results do not match",
      "retryable": false,
