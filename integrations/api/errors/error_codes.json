  "sdk_implementation_guide": {
    "description": "Guidelines for implementing error handling in each SDK",
    "required_fields": [
      "code",
      "message",
      "category"
    ],
    "optional_fields": [
      "details",
      "request_id",
      "timestamp"
    ],
    "retry_strategy": {
      "default_max_retries": 3,
      "backoff_type": "exponential",
      "initial_delay_ms": 100,
      "max_delay_ms": 30000,
      "jitter": true
    },
    "language_specific": {
      "python": {
        "base_exception": "AethelredError",
        "category_exceptions": true,
        "notes": "Use Python's exception hierarchy with specific exception classes per category"
      },
      "rust": {
        "base_error": "AethelredError",
        "result_type": "Result<T, AethelredError>",
        "notes": "Use thiserror for derive(Error), implement std::error::Error trait"
      },
      "go": {
        "base_error": "AethelredError",
        "notes": "Implement error interface, use errors.Is() and errors.As() for checking"
      },
      "typescript": {
        "base_error": "AethelredError",
        "notes": "Extend Error class, include type guards for each error category"
      }
    }
  }
}
