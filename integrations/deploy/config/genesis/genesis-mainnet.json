{
  "$schema": "https://aethelred.org/schemas/genesis-v1.json",
  "chain_id": "aethelred-1",
  "chain_name": "Aethelred Mainnet",
  "genesis_time": "2026-06-01T00:00:00.000000Z",

  "_security_note": "PRODUCTION CONFIG: AllowSimulated is explicitly false. All TEE attestation must be real hardware. Simulated proofs are rejected.",

  "consensus": {
    "type": "proof_of_compute",
    "params": {
      "block_time_ms": 6000,
      "epoch_length": 720,
      "min_validators": 4,
      "max_validators": 150,
      "compute_weight": 0.3,
      "stake_weight": 0.7,
      "vrf_threshold": "0.5"
    }
  },

  "staking": {
    "params": {
      "min_validator_stake": "100000000000000000000000",
      "min_compute_stake": "500000000000000000000000",
      "min_delegator_stake": "1000000000000000000000",
      "unbonding_period_seconds": 1209600,
      "max_validators": 150,
      "slashing": {
        "double_sign_slash_bps": 500,
        "downtime_slash_bps": 100,
        "sla_violation_slash_bps": 200,
        "jail_duration_seconds": 86400
      }
    }
  },

  "job_registry": {
    "params": {
      "min_bid": "10000000000000",
      "max_jobs_per_block": 50,
      "default_sla_timeout_seconds": 300,
      "late_penalty_bps_per_minute": 100,
      "cancellation_fee_bps": 500,
      "max_priority_multiplier": 3.0
    }
  },

  "compliance": {
    "enabled": true,
    "default_standards": ["GDPR", "CCPA"],
    "enforce_sanctions": true,
    "allow_grace_period": false,
    "risk_threshold": 75
  },

  "fee_config": {
    "prover_share_bps": 7000,
    "validator_share_bps": 2000,
    "burn_share_bps": 500,
    "treasury_share_bps": 500,
    "adaptive_burn": {
      "enabled": true,
      "base_rate_bps": 500,
      "max_rate_bps": 1500,
      "utilization_target_pct": 50
    }
  },

  "token": {
    "name": "Aethelred",
    "symbol": "AETHEL",
    "decimals": 18,
    "total_supply": "1000000000000000000000000000"
  },

  "app_state": {
    "pouw": {
      "params": {
        "allow_simulated": false,
        "min_validators": 4,
        "consensus_threshold_pct": 67,
        "job_timeout_blocks": 100,
        "require_tee_attestation": true,
        "tee_quote_max_age_seconds": 3600,
        "min_fee_per_job": "10000000000000"
      }
    },
    "verify": {
      "params": {
        "allow_simulated": false,
        "require_real_tee": true,
        "supported_tee_platforms": ["AWS_NITRO", "INTEL_SGX", "AMD_SEV"],
        "tee_quote_max_age_seconds": 3600,
        "min_attestation_count": 3
      }
    },
    "seal": {
      "params": {
        "min_validator_attestations": 3,
        "default_retention_days": 365,
        "require_tee_signature": true
      }
    }
  },

  "bridge": {
    "ethereum": {
      "chain_id": 1,
      "contract_address": "0x0000000000000000000000000000000000000000",
      "relayers": [],
      "consensus_threshold_bps": 6700,
      "challenge_period_seconds": 604800
    }
  },

  "validators": [],
  "compute_nodes": [],
  "allocations": []
}
