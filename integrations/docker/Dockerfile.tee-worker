FROM golang:1.24-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/aethelred-tee-worker ./cmd/aethelred-tee-worker

FROM alpine:3.20

RUN apk add --no-cache ca-certificates

COPY --from=builder /out/aethelred-tee-worker /usr/local/bin/aethelred-tee-worker

EXPOSE 8545

ENTRYPOINT ["/usr/local/bin/aethelred-tee-worker"]
