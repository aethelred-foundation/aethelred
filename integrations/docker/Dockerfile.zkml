FROM golang:1.24-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/aethelred-zkml-prover ./cmd/aethelred-zkml-prover

FROM alpine:3.20

RUN apk add --no-cache ca-certificates

COPY --from=builder /out/aethelred-zkml-prover /usr/local/bin/aethelred-zkml-prover

EXPOSE 8546

ENTRYPOINT ["/usr/local/bin/aethelred-zkml-prover"]
