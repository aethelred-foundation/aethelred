{
  "name": "@aethelred/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for Aethelred AI Blockchain",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./jobs": {
      "types": "./dist/jobs/index.d.ts",
      "import": "./dist/jobs/index.mjs",
      "require": "./dist/jobs/index.js"
    },
    "./seals": {
      "types": "./dist/seals/index.d.ts",
      "import": "./dist/seals/index.mjs",
      "require": "./dist/seals/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.mjs",
      "require": "./dist/models/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.mjs",
      "require": "./dist/crypto/index.js"
    },
    "./integrations": {
      "types": "./dist/integrations/index.d.ts",
      "import": "./dist/integrations/index.mjs",
      "require": "./dist/integrations/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.mjs",
      "require": "./dist/devtools/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/jobs/index.ts src/seals/index.ts src/models/index.ts src/crypto/index.ts src/integrations/index.ts src/integrations/nextjs-middleware.ts src/devtools/index.ts src/react/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/jobs/index.ts src/seals/index.ts src/models/index.ts src/crypto/index.ts src/integrations/index.ts src/integrations/nextjs-middleware.ts src/devtools/index.ts src/react/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aethelred",
    "blockchain",
    "ai",
    "machine-learning",
    "cryptography",
    "post-quantum",
    "tee",
    "zkml",
    "sdk"
  ],
  "author": "Aethelred Team <developers@aethelred.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aethelred-foundation/aethelred-sdk-ts.git"
  },
  "homepage": "https://github.com/aethelred-foundation/aethelred-sdk-ts",
  "bugs": {
    "url": "https://github.com/aethelred-foundation/aethelred-sdk-ts/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.3",
    "axios": "^1.6.5",
    "eventemitter3": "^5.0.1",
    "pino": "^8.18.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "handlebars": "^4.7.9",
    "flatted": "^3.4.2",
    "serialize-javascript": "^7.0.5",
    "undici": "^6.24.0",
    "fast-xml-parser": "^5.5.7",
    "picomatch": "^2.3.2",
    "immutable": "^4.3.8",
    "socket.io-parser": "^4.2.6",
    "underscore": "^1.13.8",
    "cookie": "^0.7.0",
    "tmp": "^0.2.4",
    "h3": "^1.15.9",
    "brace-expansion": "^2.0.3",
    "@tootallnate/once": "^3.0.1",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.31",
    "minimatch": "^9.0.7",
    "typedoc": {
      "minimatch": "9.0.7"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    }
  },
  "sideEffects": false
}
